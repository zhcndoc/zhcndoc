{
  "name": "zhcndoc",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "pnpm --filter @zhcndoc/website run dev",
    "build": "pnpm --filter @zhcndoc/website run build",
    "build:vercel": "pnpm run build && cp -r website/.vercel/output .vercel/output",
    "generate": "pnpm --filter @zhcndoc/website run generate",
    "preview": "pnpm --filter @zhcndoc/website run preview",
    "lint": "pnpm --filter @zhcndoc/website run lint",
    "lint:fix": "pnpm --filter @zhcndoc/website run lint:fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "canvas": "^3.2.3",
    "oxfmt": "^0.45.0"
  }
}
